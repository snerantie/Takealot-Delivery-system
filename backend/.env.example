# Database
DATABASE_URL="postgresql://username:password@localhost:5432/takealot_delivery?schema=public"

# Server
NODE_ENV="development"
PORT=5000
API_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (SendGrid)
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@takealot-delivery.com"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY=""

# Banking API (South African Banks)
BANK_API_URL=""
BANK_API_KEY=""
BANK_API_SECRET=""

# Google Maps
GOOGLE_MAPS_API_KEY=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
